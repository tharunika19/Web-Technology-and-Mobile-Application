<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>REC CampusNav — Shortest Path</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
  :root{
    --green-900:#0f3d2e; --green-700:#1f7a52; --green-600:#22895c; --green-500:#2ea36b;
    --bg:#eef5ef; --card:#ffffff; --text:#0f172a; --muted:#64748b; --border:#e2e8f0;
    --orange:#ea7a2a; --shadow:0 6px 20px rgba(15,61,46,.08);
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--text);
    font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Inter,sans-serif}
  header{background:linear-gradient(135deg,var(--green-900),var(--green-600));color:#fff;padding:18px 28px;
    display:flex;align-items:center;gap:14px}
  header .logo{width:42px;height:42px;border-radius:12px;background:rgba(255,255,255,.12);
    display:grid;place-items:center;font-size:20px}
  header h1{margin:0;font-size:22px;letter-spacing:.2px}
  header p{margin:2px 0 0;font-size:13px;opacity:.85}
  .wrap{max-width:1280px;margin:18px auto;padding:0 18px;display:grid;
    grid-template-columns:1fr 360px;gap:18px}
  .card{background:var(--card);border-radius:16px;box-shadow:var(--shadow);padding:16px}
  .controls{display:grid;grid-template-columns:1fr auto 1fr auto;gap:12px;align-items:end}
  .field label{display:block;font-size:11px;font-weight:600;color:var(--muted);
    letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px}
  .field label .pin{color:var(--green-600)}
  select{width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:10px;
    background:#fff;font-size:14px;color:var(--text)}
  .swap{height:40px;width:40px;border-radius:10px;border:1px solid var(--border);
    background:#fff;cursor:pointer;font-size:16px}
  .hint{font-size:12px;color:var(--muted);padding:10px 12px;border:1px dashed var(--border);
    border-radius:10px;white-space:nowrap}
  #map{height:560px;border-radius:14px;margin-top:14px;border:2px dashed #f0c000;background:#cfe8c2}
  .legend{margin-top:14px;display:flex;flex-wrap:wrap;gap:14px;align-items:center}
  .legend b{font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase}
  .lg{display:inline-flex;align-items:center;gap:6px;font-size:13px}
  .dot{width:10px;height:10px;border-radius:50%}
  .route{background:linear-gradient(135deg,var(--green-700),var(--green-500));color:#fff}
  .route .lbl{font-size:11px;letter-spacing:.1em;opacity:.85;text-transform:uppercase}
  .route .dist{font-size:38px;font-weight:800;margin-top:4px}
  .route .meta{opacity:.9;font-size:13px;margin-top:2px}
  .steps{margin-top:12px;display:flex;flex-direction:column;gap:10px}
  .step{display:flex;gap:10px;align-items:flex-start;background:#fff;border-radius:12px;
    padding:10px 12px;box-shadow:var(--shadow)}
  .step .ic{width:36px;height:36px;border-radius:10px;background:#eaf5ee;color:var(--green-700);
    display:grid;place-items:center;flex:0 0 36px;font-weight:700}
  .step.arrive .ic{background:#fdebd9;color:var(--orange)}
  .step .t{font-size:14px;font-weight:600;line-height:1.3}
  .step .s{font-size:12px;color:var(--muted);margin-top:2px}
  footer{text-align:center;color:var(--muted);font-size:12px;padding:16px}
  @media(max-width:980px){.wrap{grid-template-columns:1fr}.controls{grid-template-columns:1fr 1fr}.swap{display:none}.hint{grid-column:span 2}}
</style>
</head>
<body>
<header>
  <div class="logo">🧭</div>
  <div>
    <h1>REC CampusNav</h1>
    <p>Rajalakshmi Engineering College · Thandalam, Chennai · 13.0096°N, 80.0043°E</p>
  </div>
</header>

<div class="wrap">
  <section>
    <div class="card">
      <div class="controls">
        <div class="field">
          <label><span class="pin">📍</span> FROM</label>
          <select id="from"></select>
        </div>
        <button class="swap" id="swap" title="Swap">⇄</button>
        <div class="field">
          <label><span class="pin">🚩</span> TO</label>
          <select id="to"></select>
        </div>
        <div class="hint">Tap map → set start</div>
      </div>
      <div id="map"></div>
      <div class="legend">
        <b>Legend</b>
        <span class="lg"><span class="dot" style="background:#2ea36b"></span>Academic</span>
        <span class="lg"><span class="dot" style="background:#5a7fd6"></span>Library</span>
        <span class="lg"><span class="dot" style="background:#a06bd6"></span>Dorm</span>
        <span class="lg"><span class="dot" style="background:#e0853a"></span>Dining</span>
        <span class="lg"><span class="dot" style="background:#d24545"></span>Sports</span>
        <span class="lg"><span class="dot" style="background:#3da3a3"></span>Admin</span>
        <span class="lg"><span class="dot" style="background:#c4b03a"></span>Landmark</span>
      </div>
    </div>
  </section>

  <aside>
    <div class="card route">
      <div class="lbl">Walking route</div>
      <div class="dist" id="dist">— m</div>
      <div class="meta" id="meta">Pick start & end</div>
    </div>
    <div class="steps" id="steps"></div>
  </aside>
</div>

<footer>CampusNav · Shortest path via Dijkstra's algorithm on a campus walkway graph</footer>

<script>
// ---------- Campus graph (lat,lng around REC, Thandalam) ----------
const CENTER=[13.0096,80.0043];
const TYPES={academic:'#2ea36b',library:'#5a7fd6',dorm:'#a06bd6',dining:'#e0853a',
  sports:'#d24545',admin:'#3da3a3',landmark:'#c4b03a'};
const ICONS={academic:'🏫',library:'🏛️',dorm:'🛏️',dining:'☕',sports:'⚽',admin:'🚪',landmark:'🌳'};

const NODES=[
 {id:'admin',name:'REC Main Building (Admin)',type:'admin',ll:[13.00990,80.00380],ic:'🚪'},
 {id:'lib',name:'Central Library',type:'library',ll:[13.00955,80.00420],ic:'🏛️'},
 {id:'cse',name:'CSE Block',type:'academic',ll:[13.00945,80.00465],ic:'🏫'},
 {id:'ece',name:'ECE Block',type:'academic',ll:[13.00930,80.00500],ic:'📡'},
 {id:'mech',name:'Mech Workshop',type:'academic',ll:[13.00920,80.00540],ic:'⚙️'},
 {id:'civil',name:'Civil Block',type:'academic',ll:[13.00905,80.00455],ic:'📐'},
 {id:'chem',name:'Chemistry Lab',type:'academic',ll:[13.00895,80.00500],ic:'🧪'},
 {id:'ccd',name:'Cafe Coffee Day',type:'dining',ll:[13.00955,80.00540],ic:'☕'},
 {id:'canteen',name:'Main Canteen',type:'dining',ll:[13.00940,80.00580],ic:'🍽️'},
 {id:'pizza',name:'Pizza Corner',type:'dining',ll:[13.00975,80.00465],ic:'🍕'},
 {id:'donut',name:'Donut Shack',type:'dining',ll:[13.00970,80.00540],ic:'🍩'},
 {id:'bball',name:'Basketball Court',type:'sports',ll:[13.00945,80.00510],ic:'🏀'},
 {id:'fball',name:'Football Ground',type:'sports',ll:[13.00955,80.00580],ic:'⚽'},
 {id:'audi',name:'Auditorium',type:'landmark',ll:[13.00935,80.00610],ic:'🎭'},
 {id:'stad',name:'Stadium',type:'landmark',ll:[13.00925,80.00640],ic:'🏟️'},
 {id:'park',name:'Parking Lot',type:'landmark',ll:[13.00890,80.00440],ic:'🚗'},
 {id:'print',name:'Print Shop',type:'admin',ll:[13.00910,80.00580],ic:'🖨️'},
 {id:'bank',name:'Campus Bank',type:'admin',ll:[13.00985,80.00500],ic:'🏦'},
 {id:'hostA',name:'Boys Hostel A',type:'dorm',ll:[13.00865,80.00485],ic:'🛏️'},
 {id:'hostB',name:'Girls Hostel B',type:'dorm',ll:[13.00865,80.00540],ic:'🛌'},
 {id:'guest',name:'Guest House',type:'dorm',ll:[13.00875,80.00420],ic:'🛖'},
];

const EDGES=[
 ['admin','lib'],['admin','pizza'],['admin','bank'],
 ['lib','cse'],['lib','civil'],['lib','bank'],
 ['cse','ece'],['cse','bball'],['cse','pizza'],
 ['ece','mech'],['ece','ccd'],['ece','bball'],
 ['mech','canteen'],['mech','audi'],
 ['civil','chem'],['civil','park'],
 ['chem','print'],['chem','hostA'],
 ['ccd','donut'],['ccd','fball'],['ccd','bball'],['ccd','canteen'],
 ['canteen','fball'],['canteen','audi'],['canteen','print'],
 ['pizza','donut'],['donut','bank'],
 ['audi','stad'],['fball','stad'],
 ['print','hostB'],['hostA','hostB'],['hostA','guest'],['guest','park'],
];

// haversine meters
function dist(a,b){
  const R=6371000,toR=x=>x*Math.PI/180;
  const dLat=toR(b[0]-a[0]),dLng=toR(b[1]-a[1]);
  const s=Math.sin(dLat/2)**2+Math.cos(toR(a[0]))*Math.cos(toR(b[0]))*Math.sin(dLng/2)**2;
  return 2*R*Math.asin(Math.sqrt(s));
}
const byId=Object.fromEntries(NODES.map(n=>[n.id,n]));
const ADJ={};
NODES.forEach(n=>ADJ[n.id]=[]);
EDGES.forEach(([a,b])=>{const d=dist(byId[a].ll,byId[b].ll);ADJ[a].push([b,d]);ADJ[b].push([a,d]);});

function dijkstra(s,t){
  const D={},P={},Q=new Set(NODES.map(n=>n.id));
  NODES.forEach(n=>D[n.id]=Infinity);D[s]=0;
  while(Q.size){
    let u=null,m=Infinity;for(const x of Q)if(D[x]<m){m=D[x];u=x;}
    if(u===null||u===t)break;Q.delete(u);
    for(const [v,w] of ADJ[u]) if(Q.has(v)&&D[u]+w<D[v]){D[v]=D[u]+w;P[v]=u;}
  }
  const path=[];let c=t;while(c){path.unshift(c);if(c===s)break;c=P[c];}
  return {path,dist:D[t]};
}

// bearing
function bearing(a,b){
  const toR=x=>x*Math.PI/180,toD=x=>x*180/Math.PI;
  const y=Math.sin(toR(b[1]-a[1]))*Math.cos(toR(b[0]));
  const x=Math.cos(toR(a[0]))*Math.sin(toR(b[0]))-Math.sin(toR(a[0]))*Math.cos(toR(b[0]))*Math.cos(toR(b[1]-a[1]));
  return (toD(Math.atan2(y,x))+360)%360;
}
const COMPASS=['north','northeast','east','southeast','south','southwest','west','northwest'];
function compass(b){return COMPASS[Math.round(b/45)%8];}

// ---------- Map ----------
const map=L.map('map',{zoomControl:true,attributionControl:true}).setView(CENTER,17);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
  maxZoom:19,attribution:'© OpenStreetMap'
}).addTo(map);

NODES.forEach(n=>{
  const ic=L.divIcon({className:'',html:
    `<div style="background:${TYPES[n.type]};width:30px;height:30px;border-radius:8px;
       display:grid;place-items:center;color:#fff;font-size:16px;
       box-shadow:0 4px 10px rgba(0,0,0,.25);border:2px solid #fff">${n.ic}</div>`,
    iconSize:[30,30],iconAnchor:[15,15]});
  L.marker(n.ll,{icon:ic}).addTo(map).bindTooltip(n.name);
});

let routeLine=null,startMk=null,endMk=null;

// ---------- UI ----------
const fromSel=document.getElementById('from'),toSel=document.getElementById('to');
NODES.forEach(n=>{
  fromSel.add(new Option(n.name,n.id));
  toSel.add(new Option(n.name,n.id));
});
fromSel.value='admin';toSel.value='ccd';

function badge(letter,text){
  return L.divIcon({className:'',html:
   `<div style="background:#fff;border-radius:14px;padding:4px 10px;font-weight:700;font-size:12px;
      box-shadow:0 4px 10px rgba(0,0,0,.2);border:1px solid #e2e8f0">${letter} · ${text}</div>`,
   iconSize:[80,24],iconAnchor:[40,12]});
}

function render(){
  const s=fromSel.value,t=toSel.value;
  if(s===t){
    document.getElementById('dist').textContent='0 m';
    document.getElementById('meta').textContent='Same start & end';
    document.getElementById('steps').innerHTML='';
    if(routeLine)map.removeLayer(routeLine);
    return;
  }
  const {path,dist:D}=dijkstra(s,t);
  const coords=path.map(id=>byId[id].ll);
  if(routeLine)map.removeLayer(routeLine);
  routeLine=L.polyline(coords,{color:'#1f7a52',weight:5,opacity:.85}).addTo(map);
  if(startMk)map.removeLayer(startMk);if(endMk)map.removeLayer(endMk);
  startMk=L.marker(coords[0],{icon:badge('A',byId[s].name.split(' ')[0]+' Bldg')}).addTo(map);
  endMk=L.marker(coords[coords.length-1],{icon:badge('B',byId[t].name.split(' ')[0])}).addTo(map);
  map.fitBounds(routeLine.getBounds(),{padding:[40,40]});

  document.getElementById('dist').textContent=Math.round(D)+' m';
  const mins=Math.max(1,Math.round(D/80));
  document.getElementById('meta').textContent=`≈ ${mins} min walk · ${path.length} steps`;

  const stepsEl=document.getElementById('steps');stepsEl.innerHTML='';
  let prevB=null;
  for(let i=0;i<path.length-1;i++){
    const a=byId[path[i]],b=byId[path[i+1]];
    const br=bearing(a.ll,b.ll),dir=compass(br);
    const seg=Math.round(dist(a.ll,b.ll));
    let action='Continue',ic='→';
    if(i===0){action='Start';ic='📍';}
    else{
      const diff=((br-prevB+540)%360)-180;
      if(diff>25){action='Turn right';ic='↱';}
      else if(diff<-25){action='Turn left';ic='↰';}
    }
    const txt=i===0
      ? `Head ${dir} from ${a.name} toward the ${dir} walkway (${seg} m)`
      : action.startsWith('Turn')
        ? `${action} toward the ${dir} walkway (${seg} m)`
        : `Continue ${dir} toward the ${dir} walkway (${seg} m)`;
    stepsEl.insertAdjacentHTML('beforeend',
      `<div class="step"><div class="ic">${ic}</div>
       <div><div class="t">${txt}</div><div class="s">Step ${i+1} · ${action}</div></div></div>`);
    prevB=br;
  }
  stepsEl.insertAdjacentHTML('beforeend',
    `<div class="step arrive"><div class="ic">🚩</div>
     <div><div class="t">Arrive at ${byId[t].name}</div></div></div>`);
}

document.getElementById('swap').onclick=()=>{
  const a=fromSel.value;fromSel.value=toSel.value;toSel.value=a;render();
};
fromSel.onchange=render;toSel.onchange=render;
map.on('click',e=>{
  // pick nearest node as start
  let best=null,bd=Infinity;
  NODES.forEach(n=>{const d=dist([e.latlng.lat,e.latlng.lng],n.ll);if(d<bd){bd=d;best=n.id;}});
  if(best){fromSel.value=best;render();}
});
render();
</script>
</body>
</html>
